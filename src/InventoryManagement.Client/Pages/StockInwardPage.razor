@page "/stock-inward"
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Navigation

<PageTitle>Stock Inward Entry - AG Inventory</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-2">
    <div class="mb-6">
        <MudText Typo="Typo.h4" Class="font-weight-bold animated-gradient-text" Style="font-family: 'Outfit';">
            Stock Inward Entry
        </MudText>
        <MudText Typo="Typo.body2" Class="text-slate-400">
            Record supplier stock delivery, generate tracking codes, and snap item photos
        </MudText>
    </div>

    <EditForm EditContext="@_editContext">
        <DataAnnotationsValidator />
        
        <MudGrid>
            <!-- Inward Header Panel -->
            <MudItem xs="12" md="4">
                <MudPaper Class="glass-panel pa-6 mb-4">
                    <MudText Typo="Typo.h6" Class="text-slate-200 mb-4" Style="font-family: 'Outfit';">
                        <MudIcon Icon="@Icons.Material.Filled.Receipt" Class="mr-2" /> Header Info
                    </MudText>

                    <MudDatePicker Label="Inward Date" 
                                   @bind-Date="_inwardDate" 
                                   Required="true" 
                                   Variant="Variant.Outlined" 
                                   Class="mb-4 text-slate-200" />

                    <MudSelect T="Guid" 
                               Label="Supplier" 
                               @bind-Value="_inwardHeader.SupplierId" 
                               Required="true" 
                               RequiredError="Supplier is required"
                               Variant="Variant.Outlined" 
                               Class="mb-4 text-slate-200">
                        @foreach (var sup in _suppliers)
                        {
                            <MudSelectItem Value="@sup.Id">@sup.Code - @sup.Name</MudSelectItem>
                        }
                    </MudSelect>

                    <MudTextField T="string" 
                                  Label="Invoice Number" 
                                  @bind-Value="_inwardHeader.InvoiceNo" 
                                  Variant="Variant.Outlined" 
                                  Class="mb-4 text-slate-200" />

                    <MudDatePicker Label="Invoice Date" 
                                   @bind-Date="_invoiceDate" 
                                   Variant="Variant.Outlined" 
                                   Class="mb-4 text-slate-200" />

                    <MudTextField T="string" 
                                  Label="Batch Prefix" 
                                  Value="@_batchPrefix"
                                  ValueChanged="OnBatchPrefixChanged"
                                  Variant="Variant.Outlined" 
                                  Class="mb-4 text-slate-200" />
                </MudPaper>

                <!-- Actions -->
                <MudPaper Class="glass-panel pa-4 d-flex justify-between">
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="ResetForm">
                        Reset
                    </MudButton>
                    <MudButton OnClick="SaveInward" 
                               Variant="Variant.Filled" 
                               Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.Save"
                               Disabled="@(!_lineItems.Any() || _saving)"
                               Style="font-family: 'Outfit'; font-weight: 600;"
                               @ref="_submitButton">
                        @if (_saving)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                        }
                        else
                        {
                            <MudText>Submit Inward</MudText>
                        }
                    </MudButton>
                </MudPaper>
            </MudItem>

            <!-- Line Items Grid -->
            <MudItem xs="12" md="8">
                <MudPaper Class="glass-panel pa-6 mb-4">
                    <div class="d-flex justify-between align-center mb-4">
                        <MudText Typo="Typo.h6" Class="text-slate-200" Style="font-family: 'Outfit';">
                            <MudIcon Icon="@Icons.Material.Filled.List" Class="mr-2" /> Delivery Line Items
                        </MudText>
                        <MudButton Variant="Variant.Filled" 
                                   Color="Color.Primary" 
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="AddLineItemAsync"
                                   Size="Size.Small">
                            Add Line Row
                        </MudButton>
                    </div>

                    @if (!_lineItems.Any())
                    {
                        <div class="d-flex flex-column align-center justify-center py-8 text-center text-slate-500">
                            <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Size="Size.Large" Class="mb-2" />
                            <MudText>No items added yet. Click "Add Line Row" above.</MudText>
                        </div>
                    }
                    else
                    {
                        <div style="overflow-x: auto;">
                            <table class="w-100 mud-table" style="border-collapse: collapse;">
                                <thead>
                                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.08);">
                                        <th style="color: #94A3B8; padding: 8px; text-align: left; width: 190px;">Item</th>
                                        <th style="color: #94A3B8; padding: 8px; text-align: left; width: 150px;">Batch No</th>
                                        <th style="color: #94A3B8; padding: 8px; text-align: right; width: 110px;">Qty</th>
                                        <th style="color: #94A3B8; padding: 8px; text-align: right; width: 140px;">Rate</th>
                                        <th style="color: #94A3B8; padding: 8px; text-align: right; width: 120px;">Amount</th>
                                        <th style="color: #94A3B8; padding: 8px; text-align: center; width: 50px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < _lineItems.Count; i++)
                                    {
                                        var index = i;
                                        var line = _lineItems[index];
                                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.05); vertical-align: middle;">
                                            <td style="padding: 6px;">
                                                <MudSelect T="Guid" 
                                                           @bind-Value="line.ItemId" 
                                                           @ref="_itemRefs[index]"
                                                           @onkeydown="@((KeyboardEventArgs e) => HandleItemKeyDown(e, index))"
                                                           Margin="Margin.Dense" 
                                                           Variant="Variant.Outlined" 
                                                           Style="color: white; min-width: 170px;">
                                                    @foreach (var item in _items)
                                                    {
                                                        <MudSelectItem Value="@item.Id">@item.Name (@item.BarcodeType)</MudSelectItem>
                                                    }
                                                </MudSelect>
                                            </td>
                                            <td style="padding: 6px;">
                                                <MudTextField T="string" @bind-Value="line.BatchNo" Required="true" Margin="Margin.Dense" Variant="Variant.Outlined" Style="color: white;" />
                                            </td>
                                            <td style="padding: 6px;">
                                                <MudNumericField T="decimal" 
                                                                 @bind-Value="line.Quantity" 
                                                                 @ref="_qtyRefs[index]"
                                                                 @onkeydown="@((KeyboardEventArgs e) => HandleQtyKeyDown(e, index))"
                                                                 Min="0.01M" 
                                                                 HideSpinButtons="true" 
                                                                 Margin="Margin.Dense" 
                                                                 Variant="Variant.Outlined" 
                                                                 Style="color: white; text-align: right;" />
                                            </td>
                                            <td style="padding: 6px;">
                                                <MudNumericField T="decimal" 
                                                                 @bind-Value="line.Rate" 
                                                                 @ref="_rateRefs[index]"
                                                                 @onkeydown="@((KeyboardEventArgs e) => HandleRateKeyDown(e, index))"
                                                                 Min="0" 
                                                                 HideSpinButtons="true" 
                                                                 Format="F2" 
                                                                 Margin="Margin.Dense" 
                                                                 Variant="Variant.Outlined" 
                                                                 Style="color: white; text-align: right;" />
                                            </td>
                                            <td style="padding: 6px; text-align: right;" class="text-slate-300 font-weight-bold">
                                                ₹@((line.Quantity * line.Rate).ToString("N2"))
                                            </td>
                                            <td style="padding: 6px; text-align: center;">
                                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => RemoveLineItem(index))" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        
                        <div class="d-flex justify-end mt-4">
                            <MudText Typo="Typo.subtitle1" Class="font-weight-bold text-slate-100">
                                Total Invoice Value: <span class="animated-gradient-text" style="font-size: 20px;">₹@(_lineItems.Sum(l => l.Quantity * l.Rate).ToString("N2"))</span>
                            </MudText>
                        </div>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    </EditForm>
</MudContainer>

@code {
    private List<Supplier> _suppliers = new();
    private List<Item> _items = new();
    
    private StockInwardPostDto _inwardHeader = new();
    private EditContext? _editContext;
    private DateTime? _inwardDate = DateTime.Today;
    private DateTime? _invoiceDate;
    private List<InwardLineItem> _lineItems = new();

    private string _batchPrefix = "KS";
    private int _nextBatchSeq = 1;

    private bool _saving = false;

    private MudButton? _submitButton;

    // References for keyboard navigation
    private Dictionary<int, MudSelect<Guid>> _itemRefs = new();
    private Dictionary<int, MudNumericField<decimal>> _qtyRefs = new();
    private Dictionary<int, MudNumericField<decimal>> _rateRefs = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadLookups();
        await ResetFormAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await FocusItemSelect(0);
        }
    }

    private async Task FocusItemSelect(int index)
    {
        await Task.Delay(100);
        if (_itemRefs.TryGetValue(index, out var selectField) && selectField != null)
        {
            await selectField.FocusAsync();
        }
    }

    private async Task HandleItemKeyDown(KeyboardEventArgs e, int index)
    {
        if (e.Key == "Enter")
        {
            if (_qtyRefs.TryGetValue(index, out var qtyField) && qtyField != null)
            {
                await qtyField.FocusAsync();
            }
        }
    }

    private async Task HandleQtyKeyDown(KeyboardEventArgs e, int index)
    {
        if (e.Key == "Enter")
        {
            if (_rateRefs.TryGetValue(index, out var rateField) && rateField != null)
            {
                await rateField.FocusAsync();
            }
        }
    }

    private async Task HandleRateKeyDown(KeyboardEventArgs e, int index)
    {
        if (e.Key == "Enter")
        {
            if (_submitButton != null)
            {
                await _submitButton.FocusAsync();
            }
        }
    }

    private async Task LoadLookups()
    {
        try
        {
            _suppliers = await Http.GetFromJsonAsync<List<Supplier>>("api/masters/suppliers") ?? new();
            _items = await Http.GetFromJsonAsync<List<Item>>("api/masters/items") ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading setup masters: {ex.Message}", Severity.Error);
        }
    }

    private async Task RefreshBatchSequence()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<BatchSeqResponse>($"api/stockinward/next-batch-seq?prefix={Uri.EscapeDataString(_batchPrefix)}");
            if (response != null)
            {
                _nextBatchSeq = response.NextSeq;
            }
        }
        catch
        {
            _nextBatchSeq = 1;
        }
    }

    private async Task OnBatchPrefixChanged(string val)
    {
        _batchPrefix = val;
        await RefreshBatchSequence();
        for (int i = 0; i < _lineItems.Count; i++)
        {
            _lineItems[i].BatchNo = $"{_batchPrefix}{(_nextBatchSeq + i).ToString("D5")}";
        }
        StateHasChanged();
    }

    private void AddLineItem()
    {
        var newIndex = _lineItems.Count;
        _lineItems.Add(new InwardLineItem
        {
            ItemId = _items.FirstOrDefault()?.Id ?? Guid.Empty,
            BatchNo = $"{_batchPrefix}{(_nextBatchSeq + newIndex).ToString("D5")}",
            Quantity = 1,
            Rate = 0.00M
        });
    }

    private async Task AddLineItemAsync()
    {
        var newIndex = _lineItems.Count;
        _lineItems.Add(new InwardLineItem
        {
            ItemId = _items.FirstOrDefault()?.Id ?? Guid.Empty,
            BatchNo = $"{_batchPrefix}{(_nextBatchSeq + newIndex).ToString("D5")}",
            Quantity = 1,
            Rate = 0.00M
        });
        StateHasChanged();
        await FocusItemSelect(newIndex);
    }

    private void RemoveLineItem(int index)
    {
        if (index >= 0 && index < _lineItems.Count)
        {
            _lineItems.RemoveAt(index);
            // Clear reference dictionaries
            _itemRefs.Remove(index);
            _qtyRefs.Remove(index);
            _rateRefs.Remove(index);

            // Re-sequence batch numbers
            for (int i = 0; i < _lineItems.Count; i++)
            {
                _lineItems[i].BatchNo = $"{_batchPrefix}{(_nextBatchSeq + i).ToString("D5")}";
            }
        }
    }

    private async Task ResetFormAsync()
    {
        _inwardHeader = new StockInwardPostDto
        {
            InwardDate = DateTimeOffset.UtcNow,
            SupplierId = _suppliers.FirstOrDefault()?.Id ?? Guid.Empty
        };
        _editContext = new EditContext(_inwardHeader);
        _inwardDate = DateTime.Today;
        _invoiceDate = null;
        _lineItems.Clear();
        _itemRefs.Clear();
        _qtyRefs.Clear();
        _rateRefs.Clear();

        await RefreshBatchSequence();
        AddLineItem();
        await FocusItemSelect(0);
    }

    private async Task ResetForm()
    {
        await ResetFormAsync();
    }

    private async Task SaveInward()
    {
        if (_editContext != null && !_editContext.Validate()) return;
        if (!_lineItems.Any()) return;
        
        _saving = true;
        try
        {
            _inwardHeader.InwardDate = _inwardDate ?? DateTimeOffset.UtcNow;
            _inwardHeader.InvoiceDate = _invoiceDate;
            
            // Map details DTO
            _inwardHeader.Details = _lineItems.Select(l => new StockInwardDetailDto
            {
                ItemId = l.ItemId,
                Color = null,
                Design = null,
                Size = null,
                BatchNo = l.BatchNo,
                Quantity = l.Quantity,
                Rate = l.Rate,
                ImageUrl = null
            }).ToList();

            var response = await Http.PostAsJsonAsync("api/stockinward", _inwardHeader);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Stock Inward recorded successfully! Barcodes and QR Codes registered.", Severity.Success);
                await ResetFormAsync();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Submitting inward failed: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving inward entry: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    public class InwardLineItem
    {
        public Guid ItemId { get; set; }
        public string? Color { get; set; }
        public string? Design { get; set; }
        public string? Size { get; set; }
        public string BatchNo { get; set; } = string.Empty;
        public decimal Quantity { get; set; } = 1;
        public decimal Rate { get; set; } = 0;
        public string? ImageUrl { get; set; }
    }

    public class BatchSeqResponse
    {
        public int NextSeq { get; set; }
    }
}
