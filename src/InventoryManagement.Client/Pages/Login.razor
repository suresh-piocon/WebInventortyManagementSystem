@page "/login"
@layout MainLayout
@inject HttpClient Http
@inject ApiAuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IConfiguration Config

<div class="d-flex align-center justify-center" style="min-height: 100vh; background: radial-gradient(circle at center, #0F172A 0%, #020617 100%);">
    <MudContainer MaxWidth="MaxWidth.Small">
        <MudPaper Class="glass-panel pa-8 rounded-lg mud-elevation-24" Style="background: rgba(15, 23, 42, 0.65) !important;">
            <div class="d-flex flex-column align-center mb-6">
                <div style="background: linear-gradient(135deg, #5C5CFF 0%, #00E5FF 100%); border-radius: 50%; padding: 12px;" class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Warehouse" Size="Size.Large" Style="color: white;" />
                </div>
                <MudText Typo="Typo.h4" Class="font-weight-bold animated-gradient-text" Style="font-family: 'Outfit';">
                    AG INVENTORY
                </MudText>
                <MudText Typo="Typo.body2" Class="text-slate-400 mt-1">
                    Cloud Stock Control & Audit System
                </MudText>
            </div>

            <EditForm Model="@_loginModel" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />
                
                <MudTextField T="string" 
                              Label="Email Address" 
                              @bind-Value="_loginModel.Email" 
                              For="@(() => _loginModel.Email)"
                              Variant="Variant.Outlined" 
                              InputType="InputType.Email"
                              Adornment="Adornment.Start" 
                              AdornmentIcon="@Icons.Material.Filled.Email"
                              Class="mb-4 text-slate-200" />

                <MudTextField T="string" 
                              Label="Password" 
                              @bind-Value="_loginModel.Password" 
                              For="@(() => _loginModel.Password)"
                              Variant="Variant.Outlined" 
                              InputType="@_passwordInputType"
                              Adornment="Adornment.End" 
                              AdornmentIcon="@_passwordInputIcon"
                              OnAdornmentClick="TogglePasswordVisibility"
                              Class="mb-6 text-slate-200" />

                <MudButton ButtonType="ButtonType.Submit" 
                           Variant="Variant.Filled" 
                           Color="Color.Primary" 
                           FullWidth="true" 
                           Size="Size.Large"
                           Disabled="_loading"
                           Style="background: linear-gradient(135deg, #5C5CFF 0%, #00E5FF 100%); font-family: 'Outfit'; font-weight: 600;">
                    @if (_loading)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                        <MudText Class="ms-2">Authenticating...</MudText>
                    }
                    else
                    {
                        <MudText>Sign In</MudText>
                    }
                </MudButton>
            </EditForm>

            <div class="d-flex justify-center mt-6">
                <MudText Typo="Typo.caption" Class="text-slate-500">
                    Version 1.0.0 (Core .NET 9 + Supabase)
                </MudText>
            </div>
        </MudPaper>
    </MudContainer>
</div>

@code {
    private readonly LoginModel _loginModel = new();
    private bool _loading = false;
    private InputType _passwordInputType = InputType.Password;
    private string _passwordInputIcon = Icons.Material.Filled.Visibility;

    private void TogglePasswordVisibility()
    {
        if (_passwordInputType == InputType.Password)
        {
            _passwordInputType = InputType.Text;
            _passwordInputIcon = Icons.Material.Filled.VisibilityOff;
        }
        else
        {
            _passwordInputType = InputType.Password;
            _passwordInputIcon = Icons.Material.Filled.Visibility;
        }
    }

    private async Task HandleLogin()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            // If Supabase settings are configured, we hit the Supabase Auth API
            var supabaseUrl = Config["Supabase:Url"];
            var anonKey = Config["Supabase:AnonKey"];

            // Fallback for local simulation mode (dev mode bypass)
            if (string.IsNullOrEmpty(supabaseUrl) || supabaseUrl.Contains("your-project") || string.IsNullOrEmpty(anonKey))
            {
                var headerJson = "{\"alg\":\"HS256\",\"typ\":\"JWT\"}";
                var payloadJson = $"{{\"sub\":\"00000000-0000-0000-0000-000000000001\",\"email\":\"{_loginModel.Email}\",\"role\":\"Admin\",\"name\":\"{_loginModel.Email.Split('@')[0]} (Dev Admin)\"}}";
                
                var headerBase64 = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(headerJson)).Replace("=", "").Replace("+", "-").Replace("/", "_");
                var payloadBase64 = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(payloadJson)).Replace("=", "").Replace("+", "-").Replace("/", "_");
                var mockToken = $"{headerBase64}.{payloadBase64}.mock-signature";
                
                await AuthStateProvider.MarkUserAsAuthenticated(mockToken);
                Snackbar.Add("Logged in via Client-Side Simulation (Admin).", Severity.Success);
                
                _loading = false;
                Navigation.NavigateTo("");
                return;
            }

            // Real Supabase Auth REST Call
            using var client = new HttpClient();
            var reqUrl = $"{supabaseUrl.TrimEnd('/')}/auth/v1/token?grant_type=password";
            client.DefaultRequestHeaders.Add("apikey", anonKey);

            var payload = new { email = _loginModel.Email, password = _loginModel.Password };
            var response = await client.PostAsJsonAsync(reqUrl, payload);

            if (response.IsSuccessStatusCode)
            {
                var authResult = await response.Content.ReadFromJsonAsync<SupabaseAuthResponse>();
                if (authResult != null && !string.IsNullOrEmpty(authResult.AccessToken))
                {
                    // 1. Mark User Authenticated in Blazor State
                    await AuthStateProvider.MarkUserAsAuthenticated(authResult.AccessToken);

                    // 2. Sync profile to database
                    var syncPayload = new UserSyncDto { FullName = authResult.User?.UserMetadata?.FullName ?? _loginModel.Email.Split('@')[0] };
                    
                    // We must configure Auth Header on Http client (provider does it, but let's make sure)
                    Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", authResult.AccessToken);
                    var syncResponse = await Http.PostAsJsonAsync("api/auth/sync", syncPayload);

                    if (syncResponse.IsSuccessStatusCode)
                    {
                        Snackbar.Add("Login successful!", Severity.Success);
                        Navigation.NavigateTo("");
                    }
                    else
                    {
                        var error = await syncResponse.Content.ReadAsStringAsync();
                        Snackbar.Add($"Profile sync failed: {error}", Severity.Warning);
                        Navigation.NavigateTo("");
                    }
                }
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add("Authentication failed. Check your email and password.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            // Dev Fallback check: If Supabase connection fails completely or isn't set up,
            // let's try calling a mock login endpoint on our API so the app runs out-of-the-box!
            try
            {
                var devPayload = new { email = _loginModel.Email, password = _loginModel.Password };
                var devResponse = await Http.PostAsJsonAsync("api/auth/login-dev-mock", devPayload);
                if (devResponse.IsSuccessStatusCode)
                {
                    var devResult = await devResponse.Content.ReadFromJsonAsync<SupabaseAuthResponse>();
                    if (devResult != null && !string.IsNullOrEmpty(devResult.AccessToken))
                    {
                        await AuthStateProvider.MarkUserAsAuthenticated(devResult.AccessToken);
                        Snackbar.Add("Logged in via Local Dev Bypass Mode (Admin).", Severity.Info);
                        Navigation.NavigateTo("");
                        return;
                    }
                }
            }
            catch {}

            Snackbar.Add($"Connection error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    public class LoginModel
    {
        [Required(ErrorMessage = "Email address is required")]
        [EmailAddress(ErrorMessage = "Please enter a valid email address")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required")]
        [StringLength(100, MinimumLength = 6, ErrorMessage = "Password must be at least 6 characters")]
        public string Password { get; set; } = string.Empty;
    }

    public class SupabaseAuthResponse
    {
        [System.Text.Json.Serialization.JsonPropertyName("access_token")]
        public string AccessToken { get; set; } = string.Empty;

        [System.Text.Json.Serialization.JsonPropertyName("user")]
        public SupabaseUser? User { get; set; }
    }

    public class SupabaseUser
    {
        [System.Text.Json.Serialization.JsonPropertyName("id")]
        public Guid Id { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("user_metadata")]
        public SupabaseUserMetadata? UserMetadata { get; set; }
    }

    public class SupabaseUserMetadata
    {
        [System.Text.Json.Serialization.JsonPropertyName("full_name")]
        public string? FullName { get; set; }
    }
}
