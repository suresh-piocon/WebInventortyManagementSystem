@page "/reports/audit"
@attribute [Authorize(Roles = "Admin")]
@inject HttpClient Http
@inject ISnackbar Snackbar

<PageTitle>Data Change Audit Log - AG Inventory</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-2">
    <div class="mb-6">
        <MudText Typo="Typo.h4" Class="font-weight-bold animated-gradient-text" Style="font-family: 'Outfit';">
            Database Audit Trail
        </MudText>
        <MudText Typo="Typo.body2" Class="text-slate-400">
            Track user interactions and data state changes (INSERT, UPDATE, DELETE) with detailed property modifications
        </MudText>
    </div>

    <MudTable Items="@_logs" 
              Hover="true" 
              Loading="@_loading" 
              SearchString="@_searchString" 
              Filter="new Func<AuditLogReportDto, bool>(FilterFunc)"
              Class="glass-panel text-slate-200">
        <ToolBarContent>
            <MudText Typo="Typo.h6" Style="font-family: 'Outfit'; color: #E2E8F0;">System logs</MudText>
            <MudSpacer />
            <MudTextField @bind-Value="_searchString" 
                          Placeholder="Search logs by user, table, action..." 
                          Adornment="Adornment.Start" 
                          AdornmentIcon="@Icons.Material.Filled.Search" 
                          IconSize="Size.Medium" 
                          Class="mt-0 text-slate-200" 
                          Style="color: white;"/>
        </ToolBarContent>
        <HeaderContent>
            <MudTh Style="width: 50px;"></MudTh>
            <MudTh Style="color: #94A3B8;">Timestamp</MudTh>
            <MudTh Style="color: #94A3B8;">User Account</MudTh>
            <MudTh Style="color: #94A3B8;">Action</MudTh>
            <MudTh Style="color: #94A3B8;">Modified Table</MudTh>
            <MudTh Style="color: #94A3B8;">Record Keys</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudIconButton Icon="@(context.ShowDetails ? Icons.Material.Filled.KeyboardArrowUp : Icons.Material.Filled.KeyboardArrowDown)" 
                               Color="Color.Secondary" 
                               Size="Size.Small" 
                               OnClick="@(() => context.ShowDetails = !context.ShowDetails)" />
            </MudTd>
            <MudTd DataLabel="Timestamp" Class="text-slate-300">@context.Timestamp.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss")</MudTd>
            <MudTd DataLabel="User Account" Class="text-slate-200 font-weight-bold">@context.UserEmail</MudTd>
            <MudTd DataLabel="Action">
                @if (context.Action == "INSERT" || context.Action == "ADD")
                {
                    <MudChip T="string" Color="Color.Success" Size="Size.Small">INSERT</MudChip>
                }
                else if (context.Action == "DELETE")
                {
                    <MudChip T="string" Color="Color.Error" Size="Size.Small">DELETE</MudChip>
                }
                else
                {
                    <MudChip T="string" Color="Color.Warning" Size="Size.Small">UPDATE</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="Modified Table" Class="text-slate-200 font-weight-bold font-mono">@context.TableName</MudTd>
            <MudTd DataLabel="Record Keys" Class="text-slate-400 font-mono" Style="font-size: 11px;">@context.RecordId</MudTd>
        </RowTemplate>
        <ChildRowContent>
            @if (context.ShowDetails)
            {
                <MudTr>
                    <td colspan="6" style="background: rgba(15, 23, 42, 0.5); border-left: 3px solid #5C5CFF;">
                        <MudCard Flat="true" Style="background: transparent;" Class="pa-4 text-slate-300">
                            <MudGrid>
                                <!-- Left side: Old value -->
                                <MudItem xs="12" md="6">
                                    <MudText Typo="Typo.subtitle2" Class="text-slate-400 font-weight-bold mb-2">
                                        <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" Class="mr-1" /> Old Value (Before Modification)
                                    </MudText>
                                    @if (!string.IsNullOrEmpty(context.OldValue))
                                    {
                                        <pre style="background: #020617; padding: 12px; border-radius: 6px; font-size: 11px; overflow-x: auto; color: #EF4444; border: 1px solid rgba(239, 68, 68, 0.15);" class="font-mono">@FormatJson(context.OldValue)</pre>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.caption" Class="text-slate-500 italic">No historical values (New record creation)</MudText>
                                    }
                                </MudItem>
                                
                                <!-- Right side: New value -->
                                <MudItem xs="12" md="6">
                                    <MudText Typo="Typo.subtitle2" Class="text-slate-400 font-weight-bold mb-2">
                                        <MudIcon Icon="@Icons.Material.Filled.Backup" Size="Size.Small" Class="mr-1" /> New Value (After Modification)
                                    </MudText>
                                    @if (!string.IsNullOrEmpty(context.NewValue))
                                    {
                                        <pre style="background: #020617; padding: 12px; border-radius: 6px; font-size: 11px; overflow-x: auto; color: #10B981; border: 1px solid rgba(16, 185, 129, 0.15);" class="font-mono">@FormatJson(context.NewValue)</pre>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.caption" Class="text-slate-500 italic">No new values (Record deletion)</MudText>
                                    }
                                </MudItem>
                            </MudGrid>
                        </MudCard>
                    </td>
                </MudTr>
            }
        </ChildRowContent>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
</MudContainer>

@code {
    private List<AuditLogReportDto> _logs = new();
    private bool _loading = true;
    private string _searchString = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadLogs();
    }

    private async Task LoadLogs()
    {
        _loading = true;
        try
        {
            _logs = await Http.GetFromJsonAsync<List<AuditLogReportDto>>("api/reports/audit-logs") ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading audit trail: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private bool FilterFunc(AuditLogReportDto element) =>
        string.IsNullOrWhiteSpace(_searchString) ||
        element.TableName.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
        element.Action.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
        element.UserEmail.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
        element.RecordId.Contains(_searchString, StringComparison.OrdinalIgnoreCase);

    private string FormatJson(string jsonStr)
    {
        try
        {
            using var document = System.Text.Json.JsonDocument.Parse(jsonStr);
            return System.Text.Json.JsonSerializer.Serialize(document, new System.Text.Json.JsonSerializerOptions 
            { 
                WriteIndented = true 
            });
        }
        catch
        {
            return jsonStr;
        }
    }

    // Extended DTO with layout state
    public class AuditLogReportDto
    {
        public Guid Id { get; set; }
        public string Action { get; set; } = string.Empty;
        public string TableName { get; set; } = string.Empty;
        public string RecordId { get; set; } = string.Empty;
        public string? OldValue { get; set; }
        public string? NewValue { get; set; }
        public DateTimeOffset Timestamp { get; set; }
        public string UserEmail { get; set; } = string.Empty;
        public bool ShowDetails { get; set; } = false; // Collapsible layout state
    }
}
