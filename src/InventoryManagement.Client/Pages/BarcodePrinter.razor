@page "/barcode-printer"
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject BarcodeGeneratorService BarcodeGen
@inject IDialogService DialogService

<PageTitle>Print Barcode Labels - Inventory Management</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-2 no-print">
    <div class="mb-6">
        <MudText Typo="Typo.h4" Class="font-weight-bold animated-gradient-text" Style="font-family: 'Outfit';">
            Print Barcode & QR Labels
        </MudText>
        <MudText Typo="Typo.body2" Class="text-slate-400">
            Generate and print vector-precision Code128 barcodes and QR codes for item tracking
        </MudText>
    </div>

    <MudGrid>
        <!-- Print Configuration Panel -->
        <MudItem xs="12" md="4">
            <MudPaper Class="glass-panel pa-6 mb-4">
                <MudText Typo="Typo.h6" Class="text-slate-200 mb-4" Style="font-family: 'Outfit';">
                    <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-2" /> Label Config
                </MudText>

                <MudSelect T="string" 
                           Label="Label Format Size" 
                           @bind-Value="_labelSize" 
                           Variant="Variant.Outlined" 
                           Class="mb-4 text-slate-200">
                    <MudSelectItem Value="@("50x25")">50 x 25 mm (2 x 1 inch) - 1 per Row</MudSelectItem>
                    <MudSelectItem Value="@("50x25_double")">50 x 25 mm (2 x 1 inch) - 2 per Row</MudSelectItem>
                    <MudSelectItem Value="@("75x50")">75 x 50 mm (3 x 2 inch)</MudSelectItem>
                </MudSelect>

                <MudNumericField T="int" 
                                 Label="Print Copies Per Barcode" 
                                 @bind-Value="_copies" 
                                 Min="1" 
                                 Max="50"
                                 Variant="Variant.Outlined" 
                                 Class="mb-6 text-slate-200" />

                <MudButton Variant="Variant.Filled" 
                           Color="Color.Primary" 
                           StartIcon="@Icons.Material.Filled.Print" 
                           FullWidth="true"
                           Size="Size.Large"
                           OnClick="TriggerPrint"
                           Disabled="@(!_selectedBarcodes.Any())"
                           Style="background: linear-gradient(135deg, #5C5CFF 0%, #00E5FF 100%); font-family: 'Outfit'; font-weight: 600;">
                    Print Selected Labels (@(_selectedBarcodes.Count * _copies) total)
                </MudButton>
            </MudPaper>
        </MudItem>

        <!-- Barcode Selection List -->
        <MudItem xs="12" md="8">
            <!-- Date Filter Panel -->
            <MudPaper Class="glass-panel pa-6 mb-6">
                <MudText Typo="Typo.subtitle1" Class="text-slate-200 font-weight-bold mb-4" Style="font-family: 'Outfit';">
                    <MudIcon Icon="@Icons.Material.Filled.FilterList" Class="mr-2 text-primary" /> Filter Inward Invoices
                </MudText>
                <div class="d-flex align-center gap-4 flex-wrap">
                    <MudDatePicker Label="From Date" @bind-Date="_fromDate" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width: 160px; color: white;" />
                    <MudDatePicker Label="To Date" @bind-Date="_toDate" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width: 160px; color: white;" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search" OnClick="LoadInwards" Class="mt-1" Style="height: 40px;">
                        Fetch Inward Invoices
                    </MudButton>
                </div>
            </MudPaper>

            <!-- Stock Inwards Table -->
            <MudPaper Class="glass-panel pa-6 mb-6">
                <MudTable T="StockInward" Items="@_inwards" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0" 
                          Filter="new Func<StockInward, bool>(FilterInwardsFunc)"
                          SelectedItem="@_selectedInward" SelectedItemChanged="OnInwardSelected"
                          Style="background: transparent;">
                    <ToolBarContent>
                        <MudText Typo="Typo.h6" Class="text-slate-200" Style="font-family: 'Outfit';">
                            <MudIcon Icon="@Icons.Material.Filled.Receipt" Class="mr-2 text-primary" /> 1. Select Inward Invoice
                        </MudText>
                        <MudSpacer />
                        <MudTextField @bind-Value="InwardSearchQuery" Placeholder="Search Supplier, Invoice No..." 
                                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" 
                                      IconSize="Size.Medium" Class="mt-0 text-slate-200" Style="color: white; max-width: 320px;" />
                    </ToolBarContent>
                    <HeaderContent>
                        <MudTh Style="color: #94A3B8; width: 60px;">Select</MudTh>
                        <MudTh Style="color: #94A3B8;">Supplier Name</MudTh>
                        <MudTh Style="color: #94A3B8;">Invoice No</MudTh>
                        <MudTh Style="color: #94A3B8;">Invoice Date</MudTh>
                        <MudTh Style="color: #94A3B8; text-align: right;">Total Qty</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>
                            <MudCheckBox T="bool" 
                                         Value="@(_selectedInward?.Id == context.Id)" 
                                         ValueChanged="@((bool val) => OnInwardCheckboxChanged(val, context))" 
                                         Color="Color.Primary" 
                                         Size="Size.Small" />
                        </MudTd>
                        <MudTd DataLabel="Supplier Name" Class="text-slate-100 font-weight-bold">@context.Supplier?.Name</MudTd>
                        <MudTd DataLabel="Invoice No" Class="text-slate-200">@context.InvoiceNo</MudTd>
                        <MudTd DataLabel="Invoice Date" Class="text-slate-300">@(context.InvoiceDate?.LocalDateTime.ToString("yyyy-MM-dd") ?? "N/A")</MudTd>
                        <MudTd DataLabel="Total Qty" Style="text-align: right;" Class="text-cyan font-weight-bold">@context.Details?.Sum(d => d.Quantity).ToString("N0")</MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[]{5, 10, 20}" />
                    </PagerContent>
                </MudTable>
            </MudPaper>
 
             <!-- Barcodes Table -->
             <MudPaper Class="glass-panel pa-6">
                 <div class="d-flex justify-between align-center mb-4">
                     <MudText Typo="Typo.h6" Class="text-slate-200" Style="font-family: 'Outfit';">
                         <MudIcon Icon="@Icons.Material.Filled.FormatListBulleted" Class="mr-2 text-secondary" /> 
                         2. Select Barcodes to Print
                     </MudText>
                     @if (_barcodes.Any())
                     {
                         <div class="d-flex gap-2">
                             <MudButton Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small" OnClick="SelectAll">Select All</MudButton>
                             <MudButton Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small" OnClick="ClearSelection">Deselect All</MudButton>
                         </div>
                     }
                 </div>
 
                 @if (_loading)
                 {
                     <div class="d-flex justify-center py-8">
                         <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                     </div>
                 }
                 else if (!_barcodes.Any())
                 {
                     <div class="d-flex flex-column align-center justify-center py-8 text-center text-slate-500">
                         <MudIcon Icon="@Icons.Material.Filled.QrCode" Size="Size.Large" Class="mb-2" />
                         @if (_selectedInward == null)
                         {
                             <MudText>Select an inward invoice from the list above to display its corresponding barcodes.</MudText>
                         }
                         else
                         {
                             <MudText>No barcodes registered for this stock inward invoice.</MudText>
                         }
                     </div>
                 }
                 else
                 {
                     <div style="max-height: 450px; overflow-y: auto;">
                         <MudTable Items="@_barcodes" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0" MultiSelection="true" @bind-SelectedItems="_selectedBarcodes" Style="background: transparent;">
                             <HeaderContent>
                                 <MudTh Style="color: #94A3B8;">Item Name</MudTh>
                                 <MudTh Style="color: #94A3B8;">Barcode Number</MudTh>
                                 <MudTh Style="color: #94A3B8;">Batch No</MudTh>
                                 <MudTh Style="color: #94A3B8;">Tracking No</MudTh>
                                 <MudTh Style="color: #94A3B8;">Type</MudTh>
                                 <MudTh Style="color: #94A3B8;">Status</MudTh>
                                 <MudTh Style="color: #94A3B8; text-align: center; width: 60px;">Actions</MudTh>
                             </HeaderContent>
                             <RowTemplate>
                                 <MudTd DataLabel="Item Name" Class="text-slate-100 font-weight-bold">@context.Item?.Name</MudTd>
                                 <MudTd DataLabel="Barcode Number" Class="text-slate-100 font-mono font-weight-bold">@context.Barcode</MudTd>
                                 <MudTd DataLabel="Batch No" Class="text-slate-200">@context.BatchNo</MudTd>
                                 <MudTd DataLabel="Tracking No" Class="text-slate-300 font-mono" Style="font-size: 12px;">@context.TrackingNo</MudTd>
                                 <MudTd DataLabel="Type" Class="text-slate-300">@context.Type</MudTd>
                                 <MudTd DataLabel="Status">
                                     @if (context.IsUsed)
                                     {
                                         <MudChip T="string" Color="Color.Error" Size="Size.Small" Variant="Variant.Text">Used / Outward</MudChip>
                                     }
                                     else
                                     {
                                         <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Text">Available</MudChip>
                                     }
                                 </MudTd>
                                 <MudTd DataLabel="Actions" Style="text-align: center;">
                                     <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                                    Color="Color.Error" 
                                                    Size="Size.Small" 
                                                    OnClick="@(() => ConfirmDeleteBarcode(context))" />
                                 </MudTd>
                             </RowTemplate>
                         </MudTable>
                     </div>
                 }
             </MudPaper>
        </MudItem>
    </MudGrid>

    <!-- Visual Interactive Screen Preview (Non-printed layout) -->
    @if (_selectedBarcodes.Any())
    {
        var previewLabels = GetLabelsToPrint();
        <MudPaper Class="glass-panel pa-6 mt-6">
            <MudText Typo="Typo.h6" Class="text-slate-200 mb-4" Style="font-family: 'Outfit';">
                Label Screen Preview (Print Layout Visualization)
            </MudText>
            
            <div class="d-flex flex-column align-center w-100" style="max-height: 500px; overflow-y: auto; background: rgba(0,0,0,0.2); padding: 20px; border-radius: 8px;">
                @if (_labelSize == "50x25_double")
                {
                    @for (int i = 0; i < previewLabels.Count; i += 2)
                    {
                        var leftLabel = previewLabels[i];
                        var rightLabel = i + 1 < previewLabels.Count ? previewLabels[i + 1] : null;

                        <div class="d-flex justify-center gap-4 mb-4" style="width: 100%;">
                            <!-- Left Label -->
                            <div class="pa-2 rounded d-flex flex-column align-center justify-between" style="width: 250px; height: 125px; background: white; color: black; border: 1px dashed #5C5CFF; box-shadow: 0 0 10px rgba(92,92,255,0.15);">
                                <div class="w-100 d-flex justify-between" style="font-size: 10px; font-weight: bold; border-bottom: 1px solid #ddd; padding-bottom: 2px;">
                                    <div style="max-width: 140px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@leftLabel.ItemName</div>
                                    <div>@leftLabel.BatchNo</div>
                                </div>
                                <div class="d-flex align-center justify-center w-100 px-1 py-1">
                                    <div style="width: 190px; height: auto; display: flex; justify-content: center; align-items: center;">
                                        @((MarkupString)leftLabel.BarcodeSvg)
                                    </div>
                                </div>
                                <div style="font-size: 9px; font-family: monospace; color: #333; text-align: center; width: 100%;">@leftLabel.Barcode</div>
                            </div>

                            <!-- Right Label -->
                            @if (rightLabel != null)
                            {
                                <div class="pa-2 rounded d-flex flex-column align-center justify-between" style="width: 250px; height: 125px; background: white; color: black; border: 1px dashed #5C5CFF; box-shadow: 0 0 10px rgba(92,92,255,0.15);">
                                    <div class="w-100 d-flex justify-between" style="font-size: 10px; font-weight: bold; border-bottom: 1px solid #ddd; padding-bottom: 2px;">
                                        <div style="max-width: 140px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@rightLabel.ItemName</div>
                                        <div>@rightLabel.BatchNo</div>
                                    </div>
                                    <div class="d-flex align-center justify-center w-100 px-1 py-1">
                                        <div style="width: 190px; height: auto; display: flex; justify-content: center; align-items: center;">
                                            @((MarkupString)rightLabel.BarcodeSvg)
                                        </div>
                                    </div>
                                    <div style="font-size: 9px; font-family: monospace; color: #333; text-align: center; width: 100%;">@rightLabel.Barcode</div>
                                </div>
                            }
                            else
                            {
                                <div style="width: 250px; height: 125px; border: 1px dashed rgba(255,255,255,0.1); visibility: hidden;"></div>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="d-flex flex-wrap gap-4 justify-center">
                        @foreach (var label in previewLabels)
                        {
                            @if (_labelSize == "50x25")
                            {
                                <div class="pa-2 rounded d-flex flex-column align-center justify-between" style="width: 250px; height: 125px; background: white; color: black; border: 1px dashed #5C5CFF; box-shadow: 0 0 10px rgba(92,92,255,0.15);">
                                    <div class="w-100 d-flex justify-between" style="font-size: 10px; font-weight: bold; border-bottom: 1px solid #ddd; padding-bottom: 2px;">
                                        <div style="max-width: 140px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@label.ItemName</div>
                                        <div>@label.BatchNo</div>
                                    </div>
                                    <div class="d-flex align-center justify-center w-100 px-1 py-1">
                                        <div style="width: 190px; height: auto; display: flex; justify-content: center; align-items: center;">
                                            @((MarkupString)label.BarcodeSvg)
                                        </div>
                                    </div>
                                    <div style="font-size: 9px; font-family: monospace; color: #333; text-align: center; width: 100%;">@label.Barcode</div>
                                </div>
                            }
                            else
                            {
                                <div class="pa-4 rounded d-flex flex-column align-center justify-between" style="width: 300px; height: 200px; background: white; color: black; border: 1px dashed #5C5CFF; box-shadow: 0 0 10px rgba(92,92,255,0.15);">
                                    <div class="w-100 text-center" style="border-bottom: 2px solid black; padding-bottom: 4px; margin-bottom: 4px;">
                                        <div class="font-weight-bold" style="font-size: 14px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@label.ItemName</div>
                                        <div style="font-size: 11px; color: #444;">Batch No: <b>@label.BatchNo</b></div>
                                    </div>
                                    <div class="d-flex align-center justify-center w-100 py-2">
                                        <div style="width: 240px; height: auto; display: flex; justify-content: center; align-items: center;">
                                            @((MarkupString)label.BarcodeSvg)
                                        </div>
                                    </div>
                                    <div class="w-100 d-flex justify-between" style="font-size: 9px; font-family: monospace; color: #333; border-top: 1px solid #eee; padding-top: 2px;">
                                        <div>Barcode: @label.Barcode</div>
                                        <div>Size: 75x50mm</div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                }
            </div>
        </MudPaper>
    }
</MudContainer>

<!-- Printable Sheet (Only visible during @media print) -->
<div class="printable-sheet d-none">
    @{
        var labels = GetLabelsToPrint();
    }
    @if (_labelSize == "50x25_double")
    {
        @for (int i = 0; i < labels.Count; i += 2)
        {
            var leftLabel = labels[i];
            var rightLabel = i + 1 < labels.Count ? labels[i + 1] : null;

            <div class="label-row-50-25">
                <div class="label-50-25-double">
                    <div style="width: 100%; display: flex; justify-content: space-between; font-size: 8px; font-weight: bold; border-bottom: 0.5px solid #000; padding-bottom: 1px; font-family: sans-serif;">
                        <span style="max-width: 140px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@leftLabel.ItemName</span>
                        <span>@leftLabel.BatchNo</span>
                    </div>
                    <div style="display: flex; align-items: center; justify-content: center; width: 100%; height: 16mm;">
                        <div style="width: 44mm; height: 12mm; overflow: hidden; display: flex; justify-content: center; align-items: center;">
                            @((MarkupString)leftLabel.BarcodeSvg)
                        </div>
                    </div>
                    <div style="font-size: 8px; font-family: monospace; text-align: center; width: 100%;">@leftLabel.Barcode</div>
                </div>

                @if (rightLabel != null)
                {
                    <div class="label-50-25-double">
                        <div style="width: 100%; display: flex; justify-content: space-between; font-size: 8px; font-weight: bold; border-bottom: 0.5px solid #000; padding-bottom: 1px; font-family: sans-serif;">
                            <span style="max-width: 140px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@rightLabel.ItemName</span>
                            <span>@rightLabel.BatchNo</span>
                        </div>
                        <div style="display: flex; align-items: center; justify-content: center; width: 100%; height: 16mm;">
                            <div style="width: 44mm; height: 12mm; overflow: hidden; display: flex; justify-content: center; align-items: center;">
                                @((MarkupString)rightLabel.BarcodeSvg)
                            </div>
                        </div>
                        <div style="font-size: 8px; font-family: monospace; text-align: center; width: 100%;">@rightLabel.Barcode</div>
                    </div>
                }
                else
                {
                    <!-- Empty label placeholder to keep spacing -->
                    <div class="label-50-25-double" style="visibility: hidden;"></div>
                }
            </div>
        }
    }
    else
    {
        @foreach (var label in labels)
        {
            @if (_labelSize == "50x25")
            {
                <div class="label-50-25">
                    <div style="width: 100%; display: flex; justify-content: space-between; font-size: 8px; font-weight: bold; border-bottom: 0.5px solid #000; padding-bottom: 1px; font-family: sans-serif;">
                        <span style="max-width: 140px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@label.ItemName</span>
                        <span>@label.BatchNo</span>
                    </div>
                    <div style="display: flex; align-items: center; justify-content: center; width: 100%; height: 16mm;">
                        <div style="width: 44mm; height: 12mm; overflow: hidden; display: flex; justify-content: center; align-items: center;">
                            @((MarkupString)label.BarcodeSvg)
                        </div>
                    </div>
                    <div style="font-size: 8px; font-family: monospace; text-align: center; width: 100%;">@label.Barcode</div>
                </div>
            }
            else
            {
                <div class="label-75-50">
                    <div style="width: 100%; text-align: center; border-bottom: 1px solid #000; padding-bottom: 2px; font-family: sans-serif;">
                        <div style="font-size: 11px; font-weight: bold; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@label.ItemName</div>
                        <div style="font-size: 8px; color: #333;">Batch: <b>@label.BatchNo</b></div>
                    </div>
                    
                    <div style="display: flex; align-items: center; justify-content: center; width: 100%; height: 32mm;">
                        <div style="width: 68mm; height: auto; display: flex; justify-content: center; align-items: center;">
                            @((MarkupString)label.BarcodeSvg)
                        </div>
                    </div>
                    
                    <div style="width: 100%; display: flex; justify-content: space-between; font-size: 8px; font-family: monospace; border-top: 0.5px solid #ccc; padding-top: 1px;">
                        <div>Barcode: @label.Barcode</div>
                        <div>Inventory Management</div>
                    </div>
                </div>
            }
        }
    }
</div>

<style>
    /* Styling to hide sidebar and main layout when printing, and show printable-sheet */
    @@media print {
        .no-print {
            display: none !important;
        }
        .printable-sheet {
            display: block !important;
        }
    }
</style>

@code {
    private List<BarcodeMaster> _barcodes = new();
    private HashSet<BarcodeMaster> _selectedBarcodes = new();
    
    private string _labelSize = "50x25";
    private int _copies = 1;
    private bool _loading = false;

    private DateTime? _fromDate = DateTime.Today.AddMonths(-1);
    private DateTime? _toDate = DateTime.Today;

    private List<StockInward> _inwards = new();
    private StockInward? _selectedInward = null;
    private string _inwardSearchQuery = "";

    private string InwardSearchQuery
    {
        get => _inwardSearchQuery;
        set
        {
            if (_inwardSearchQuery != value)
            {
                _inwardSearchQuery = value;
                if (_selectedInward != null && !FilterInwardsFunc(_selectedInward))
                {
                    _selectedInward = null;
                    _barcodes.Clear();
                    _selectedBarcodes.Clear();
                }
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadInwards();
    }

    private async Task LoadInwards()
    {
        _loading = true;
        _selectedInward = null;
        _barcodes.Clear();
        _selectedBarcodes.Clear();
        StateHasChanged();

        try
        {
            var startQuery = _fromDate.HasValue ? $"startDate={_fromDate.Value:yyyy-MM-dd}" : "";
            var endQuery = _toDate.HasValue ? $"endDate={_toDate.Value:yyyy-MM-dd}" : "";
            var query = string.Join("&", new[] { startQuery, endQuery }.Where(s => !string.IsNullOrEmpty(s)));
            var url = string.IsNullOrEmpty(query) ? "api/stockinward" : $"api/stockinward?{query}";

            _inwards = await Http.GetFromJsonAsync<List<StockInward>>(url) ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading stock inwards: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task OnInwardSelected(StockInward? inward)
    {
        _selectedInward = inward;
        if (inward != null)
        {
            await LoadBarcodesForInward(inward.Id);
        }
        else
        {
            _barcodes.Clear();
            _selectedBarcodes.Clear();
        }
    }

    private async Task OnInwardCheckboxChanged(bool val, StockInward inward)
    {
        if (val)
        {
            await OnInwardSelected(inward);
        }
        else
        {
            if (_selectedInward?.Id == inward.Id)
            {
                await OnInwardSelected(null);
            }
        }
    }

    private async Task ConfirmDeleteBarcode(BarcodeMaster barcode)
    {
        bool? confirm = await DialogService.ShowMessageBoxAsync(
            "Delete Barcode Record", 
            $"Are you sure you want to delete the barcode '{barcode.Barcode}' for item '{barcode.Item?.Name}'? This will also decrement the inward quantity and associated ledger data.", 
            yesText: "Delete", cancelText: "Cancel");

        if (confirm == true)
        {
            try
            {
                var response = await Http.DeleteAsync($"api/stockinward/barcode/{barcode.Id}");
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Barcode and associated inward detail updated/deleted successfully!", Severity.Success);
                    
                    // Keep track of the selected inward ID before loadingwards
                    var prevInwardId = _selectedInward?.Id;
                    
                    await LoadInwards();
                    
                    if (prevInwardId.HasValue)
                    {
                        var stillExists = _inwards.FirstOrDefault(i => i.Id == prevInwardId.Value);
                        if (stillExists != null)
                        {
                            _selectedInward = stillExists;
                            await LoadBarcodesForInward(_selectedInward.Id);
                        }
                    }
                }
                else
                {
                    var error = await response.Content.ReadAsStringAsync();
                    Snackbar.Add($"Delete failed: {error}", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting barcode: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task LoadBarcodesForInward(Guid inwardId)
    {
        _loading = true;
        _selectedBarcodes.Clear();
        StateHasChanged();

        try
        {
            _barcodes = await Http.GetFromJsonAsync<List<BarcodeMaster>>($"api/reports/barcodes/inward/{inwardId}") ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading barcodes for stock inward: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private bool FilterInwardsFunc(StockInward element)
    {
        if (string.IsNullOrWhiteSpace(_inwardSearchQuery))
            return true;

        if (element.Supplier?.Name?.Contains(_inwardSearchQuery, StringComparison.OrdinalIgnoreCase) == true)
            return true;

        if (element.InvoiceNo?.Contains(_inwardSearchQuery, StringComparison.OrdinalIgnoreCase) == true)
            return true;

        if (element.InvoiceDate?.LocalDateTime.ToString("yyyy-MM-dd").Contains(_inwardSearchQuery, StringComparison.OrdinalIgnoreCase) == true)
            return true;

        if (element.InwardNo.Contains(_inwardSearchQuery, StringComparison.OrdinalIgnoreCase))
            return true;

        return false;
    }

    private void SelectAll()
    {
        _selectedBarcodes = new HashSet<BarcodeMaster>(_barcodes);
    }

    private void ClearSelection()
    {
        _selectedBarcodes.Clear();
    }

    private string GetQRJson(BarcodeMaster codeItem)
    {
        var qrData = new
        {
            TrackingNo = codeItem.TrackingNo,
            Item = codeItem.Item?.Name ?? "",
            Batch = codeItem.BatchNo,
            Barcode = codeItem.Barcode
        };
        return System.Text.Json.JsonSerializer.Serialize(qrData);
    }

    private async Task TriggerPrint()
    {
        if (!_selectedBarcodes.Any()) return;
        
        // Brief delay to allow DOM to synchronize
        await Task.Delay(200);
        
        // Trigger browser print dialog
        await JSRuntime.InvokeVoidAsync("window.print");
    }

    private class LabelPrintItem
    {
        public string ItemName { get; set; } = "";
        public string Barcode { get; set; } = "";
        public string BatchNo { get; set; } = "";
        public string TrackingNo { get; set; } = "";
        public string BarcodeSvg { get; set; } = "";
        public string QrSvg { get; set; } = "";
    }

    private List<LabelPrintItem> GetLabelsToPrint()
    {
        var list = new List<LabelPrintItem>();
        foreach (var codeItem in _selectedBarcodes)
        {
            var barcodeSvg = BarcodeGen.GenerateBarcodeSvg(codeItem.Barcode);
            var qrContent = GetQRJson(codeItem);
            var qrSvg = BarcodeGen.GenerateQRCodeSvg(qrContent);
            
            for (int c = 0; c < _copies; c++)
            {
                list.Add(new LabelPrintItem
                {
                    ItemName = codeItem.Item?.Name ?? "",
                    Barcode = codeItem.Barcode,
                    BatchNo = codeItem.BatchNo,
                    TrackingNo = codeItem.TrackingNo,
                    BarcodeSvg = barcodeSvg,
                    QrSvg = qrSvg
                });
            }
        }
        return list;
    }
}
