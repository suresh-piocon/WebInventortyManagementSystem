@page "/"
@inject HttpClient Http
@inject ISnackbar Snackbar

<PageTitle>Dashboard - Inventory Management</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-2">
    <div class="d-flex justify-between align-center mb-6">
        <div>
            <MudText Typo="Typo.h4" Class="font-weight-bold animated-gradient-text" Style="font-family: 'Outfit';">
                Dashboard Overview
            </MudText>
            <MudText Typo="Typo.body2" Class="text-slate-400">
                Real-time stock valuation and logistics monitoring
            </MudText>
        </div>
        <div class="d-flex align-center gap-2">
            <MudSelect T="string" Label="Stock Valuation" Value="@_valuationMethod" ValueChanged="OnValuationChanged" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width: 200px; color: white;">
                <MudSelectItem Value="@("WeightedAverage")">Weighted Average</MudSelectItem>
                <MudSelectItem Value="@("FIFO")">FIFO Method</MudSelectItem>
            </MudSelect>
            <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Primary" OnClick="LoadData" />
        </div>
    </div>

    @if (_loading)
    {
        <div class="d-flex justify-center align-center" style="min-height: 400px;">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
        </div>
    }
    else if (_data != null)
    {
        <!-- Metrics Row -->
        <MudGrid Class="mb-6">
            <MudItem xs="12" sm="6" md="4" lg="2">
                <MudPaper Class="glass-card pa-4 d-flex align-center justify-between">
                    <div>
                        <MudText Typo="Typo.caption" Class="text-slate-400">Total Suppliers</MudText>
                        <MudText Typo="Typo.h5" Class="font-weight-bold mt-1 text-slate-100">@_data.TotalSuppliers</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.Business" Color="Color.Primary" Size="Size.Large" />
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" md="4" lg="2">
                <MudPaper Class="glass-card pa-4 d-flex align-center justify-between">
                    <div>
                        <MudText Typo="Typo.caption" Class="text-slate-400">Total Items</MudText>
                        <MudText Typo="Typo.h5" Class="font-weight-bold mt-1 text-slate-100">@_data.TotalItems</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.Layers" Color="Color.Secondary" Size="Size.Large" />
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" md="4" lg="2">
                <MudPaper Class="glass-card pa-4 d-flex align-center justify-between">
                    <div>
                        <MudText Typo="Typo.caption" Class="text-slate-400">Today's Inward</MudText>
                        <MudText Typo="Typo.h5" Class="font-weight-bold mt-1 text-slate-100">@_data.TodayInward</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.MoveToInbox" Color="Color.Success" Size="Size.Large" />
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="6" md="4" lg="2">
                <MudPaper Class="glass-card pa-4 d-flex align-center justify-between">
                    <div>
                        <MudText Typo="Typo.caption" Class="text-slate-400">Today's Outward</MudText>
                        <MudText Typo="Typo.h5" Class="font-weight-bold mt-1 text-slate-100">@_data.TodayOutward</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.Outbox" Color="Color.Error" Size="Size.Large" />
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="12" md="8" lg="4">
                <MudPaper Class="glass-card pa-4 d-flex align-center justify-between" Style="border: 1px solid rgba(0, 229, 255, 0.2) !important;">
                    <div>
                        <MudText Typo="Typo.caption" Class="text-slate-400">Current Stock Value (@_valuationMethod)</MudText>
                        <MudText Typo="Typo.h5" Class="font-weight-bold mt-1" Style="color: #00E5FF; font-family: 'Outfit';">
                            ₹@_data.CurrentStockValue.ToString("N2")
                        </MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.MonetizationOn" Color="Color.Secondary" Size="Size.Large" />
                </MudPaper>
            </MudItem>
        </MudGrid>

        <!-- Charts Row -->
        <MudGrid Class="mb-6">
            <MudItem xs="12" md="8">
                <MudPaper Class="glass-panel pa-6">
                    <MudText Typo="Typo.h6" Class="text-slate-200 mb-4" Style="font-family: 'Outfit';">
                        Monthly Stock Movement (Volume)
                    </MudText>
                    @if (_chartSeries.Any())
                    {
                        <MudChart T="double" 
                                  ChartType="ChartType.Line" 
                                  ChartSeries="@_chartSeries" 
                                  XAxisLabels="@_chartLabels" 
                                  Width="100%" 
                                  Height="300px" 
                                  ChartOptions="@_chartOptions" />
                    }
                    else
                    {
                        <div class="d-flex align-center justify-center" style="height: 300px;">
                            <MudText Class="text-slate-500">No chart data available</MudText>
                        </div>
                    }
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Class="glass-panel pa-6 d-flex flex-column" Style="height: 100%;">
                    <MudText Typo="Typo.h6" Class="text-slate-200 mb-4" Style="font-family: 'Outfit';">
                        Top Suppliers (Qty Purchased)
                    </MudText>
                    @if (_donutData.Any())
                    {
                        <div class="d-flex align-center justify-center flex-grow-1">
                            <MudChart T="double" 
                                      ChartType="ChartType.Donut" 
                                      InputData="@_donutData.ToArray()" 
                                      InputLabels="@_donutLabels.ToArray()" 
                                      Width="250px" 
                                      Height="250px" />
                        </div>
                    }
                    else
                    {
                        <div class="d-flex align-center justify-center flex-grow-1">
                            <MudText Class="text-slate-500">No supplier data available</MudText>
                        </div>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>

        <!-- Warnings / Low Stock Grid -->
        <MudGrid>
            <MudItem xs="12">
                <MudCard Class="glass-panel">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6" Color="Color.Warning" Class="font-weight-bold" Style="font-family: 'Outfit';">
                                <MudIcon Icon="@Icons.Material.Filled.Warning" Class="mr-2" /> Low Stock & Reorder Alerts
                            </MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudChip T="string" Color="Color.Warning" Size="Size.Small" Variant="Variant.Text">
                                @_data.LowStockItems.Count Items Require Reorder
                            </MudChip>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent Class="pa-0">
                        @if (_data.LowStockItems.Any())
                        {
                            <MudTable Items="@_data.LowStockItems" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0" Style="background: transparent;">
                                <HeaderContent>
                                    <MudTh Style="color: #94A3B8;">Item Code</MudTh>
                                    <MudTh Style="color: #94A3B8;">Item Name</MudTh>
                                    <MudTh Style="color: #94A3B8;">Min Stock</MudTh>
                                    <MudTh Style="color: #94A3B8;">Reorder Level</MudTh>
                                    <MudTh Style="color: #94A3B8;">Current Stock</MudTh>
                                    <MudTh Style="color: #94A3B8; text-align: right;">Status</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Item Code" Class="text-slate-300">@context.ItemCode</MudTd>
                                    <MudTd DataLabel="Item Name" Class="text-slate-200 font-weight-bold">@context.ItemName</MudTd>
                                    <MudTd DataLabel="Min Stock" Class="text-slate-300">@context.MinStock.ToString("N2") @context.UnitCode</MudTd>
                                    <MudTd DataLabel="Reorder Level" Class="text-slate-300">@context.ReorderLevel.ToString("N2") @context.UnitCode</MudTd>
                                    <MudTd DataLabel="Current Stock" Class="text-slate-100 font-weight-bold">
                                        <span class="@(context.CurrentStock <= context.MinStock ? "text-red-500 font-bold" : "text-yellow-500")">
                                            @context.CurrentStock.ToString("N2") @context.UnitCode
                                        </span>
                                    </MudTd>
                                    <MudTd DataLabel="Status" Style="text-align: right;">
                                        @if (context.CurrentStock <= context.MinStock)
                                        {
                                            <MudChip T="string" Color="Color.Error" Size="Size.Small">CRITICAL</MudChip>
                                        }
                                        else
                                        {
                                            <MudChip T="string" Color="Color.Warning" Size="Size.Small">REORDER</MudChip>
                                        }
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <div class="d-flex align-center justify-center py-6">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Class="mr-2" />
                                <MudText Class="text-slate-400">All item stock levels are healthy.</MudText>
                            </div>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    private bool _loading = true;
    private string _valuationMethod = "WeightedAverage";
    private DashboardDto? _data;

    private List<ChartSeries<double>> _chartSeries = new();
    private string[] _chartLabels = Array.Empty<string>();
    private readonly ChartOptions _chartOptions = new();

    private List<double> _donutData = new();
    private List<string> _donutLabels = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task OnValuationChanged(string method)
    {
        _valuationMethod = method;
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            _data = await Http.GetFromJsonAsync<DashboardDto>($"api/reports/dashboard?valuationMethod={_valuationMethod}");
            if (_data != null)
            {
                // Format Monthly Movements Chart
                _chartLabels = _data.MonthlyChartData.Select(d => d.MonthName).ToArray();
                
                _chartSeries = new List<ChartSeries<double>>
                {
                    new ChartSeries<double> { Name = "Inward Stock", Data = _data.MonthlyChartData.Select(d => (double)d.InwardQty).ToArray() },
                    new ChartSeries<double> { Name = "Outward Stock", Data = _data.MonthlyChartData.Select(d => (double)d.OutwardQty).ToArray() }
                };

                // Format Top Suppliers Donut Chart
                _donutData = _data.TopSuppliers.Select(s => (double)s.TotalQty).ToList();
                _donutLabels = _data.TopSuppliers.Select(s => $"{s.SupplierName} ({s.TotalQty:N0})").ToList();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading dashboard: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }
}
