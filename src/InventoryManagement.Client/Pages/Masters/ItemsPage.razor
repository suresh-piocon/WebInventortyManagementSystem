@page "/masters/items"
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Item Master - Inventory Management</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-2">
    <div class="d-flex justify-between align-center mb-6">
        <div>
            <MudText Typo="Typo.h4" Class="font-weight-bold animated-gradient-text" Style="font-family: 'Outfit';">
                Item Master
            </MudText>
            <MudText Typo="Typo.body2" Class="text-slate-400">
                Configure item specifications, reorder levels, and tracking configurations
            </MudText>
        </div>
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenAddDialog"
                   Style="background: linear-gradient(135deg, #5C5CFF 0%, #00E5FF 100%); font-family: 'Outfit'; font-weight: 600;">
            Add Item
        </MudButton>
    </div>

    <MudTable Items="@_items" 
              Hover="true" 
              Loading="@_loading" 
              SearchString="@_searchString" 
              Filter="new Func<Item, bool>(FilterFunc)"
              Class="glass-panel text-slate-200">
        <ToolBarContent>
            <MudText Typo="Typo.h6" Style="font-family: 'Outfit'; color: #E2E8F0;">Items list</MudText>
            <MudSpacer />
            <MudTextField @bind-Value="_searchString" 
                          Placeholder="Search items..." 
                          Adornment="Adornment.Start" 
                          AdornmentIcon="@Icons.Material.Filled.Search" 
                          IconSize="Size.Medium" 
                          Class="mt-0 text-slate-200" 
                          Style="color: white;"/>
        </ToolBarContent>
        <HeaderContent>
            <MudTh Style="color: #94A3B8;">Code</MudTh>
            <MudTh Style="color: #94A3B8;">Item Name</MudTh>
            <MudTh Style="color: #94A3B8;">Category</MudTh>
            <MudTh Style="color: #94A3B8;">Brand</MudTh>
            <MudTh Style="color: #94A3B8;">Unit</MudTh>
            <MudTh Style="color: #94A3B8;">Min Stock</MudTh>
            <MudTh Style="color: #94A3B8;">Reorder Level</MudTh>
            <MudTh Style="color: #94A3B8;">Tracking Type</MudTh>
            <MudTh Style="color: #94A3B8; text-align: right;">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Code" Class="text-slate-100 font-weight-bold">@context.Code</MudTd>
            <MudTd DataLabel="Item Name" Class="text-slate-200 font-weight-bold">@context.Name</MudTd>
            <MudTd DataLabel="Category" Class="text-slate-300">@context.Category?.Name</MudTd>
            <MudTd DataLabel="Brand" Class="text-slate-300">@context.Brand</MudTd>
            <MudTd DataLabel="Unit" Class="text-slate-300">@context.Unit?.Code</MudTd>
            <MudTd DataLabel="Min Stock" Class="text-slate-300">@context.MinimumStock.ToString("N2")</MudTd>
            <MudTd DataLabel="Reorder Level" Class="text-slate-300">@context.ReorderLevel.ToString("N2")</MudTd>
            <MudTd DataLabel="Tracking Type">
                @if (context.BarcodeType == "Unique")
                {
                    <MudChip T="string" Color="Color.Secondary" Size="Size.Small" Variant="Variant.Text">Unique Piece</MudChip>
                }
                else
                {
                    <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Text">Batch Quantity</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="Actions" Style="text-align: right;">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Info" Size="Size.Small" OnClick="@(() => OpenEditDialog(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => ConfirmDelete(context))" />
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
</MudContainer>

<!-- Dialog for Add/Edit -->
<MudDialog @bind-Visible="_dialogOpen" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="font-family: 'Outfit'; color: white;">
            @(_editItem.Id == Guid.Empty ? "Create New Item" : "Edit Item")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isFormValid">
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Item Code" @bind-Value="_editItem.Code" Required="true" RequiredError="Item code is required" Class="text-slate-200" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Item Name" @bind-Value="_editItem.Name" Required="true" RequiredError="Item name is required" Class="text-slate-200" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="Guid" Label="Category" @bind-Value="_editItem.CategoryId" Required="true" RequiredError="Category is required" Class="text-slate-200">
                        @foreach (var cat in _categories)
                        {
                            <MudSelectItem Value="@cat.Id">@cat.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="Guid" Label="Unit of Measure" @bind-Value="_editItem.UnitId" Required="true" RequiredError="Unit is required" Class="text-slate-200">
                        @foreach (var unit in _units)
                        {
                            <MudSelectItem Value="@unit.Id">@unit.Code - @unit.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Brand Name" @bind-Value="_editItem.Brand" Class="text-slate-200" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="HSN Code" @bind-Value="_editItem.HSNCode" Class="text-slate-200" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField T="decimal" Label="Minimum Stock" @bind-Value="_editItem.MinimumStock" Min="0" Class="text-slate-200" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField T="decimal" Label="Reorder Level" @bind-Value="_editItem.ReorderLevel" Min="0" Class="text-slate-200" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="string" Label="Barcode Tracking Type" @bind-Value="_editItem.BarcodeType" Required="true" Class="text-slate-200">
                        <MudSelectItem Value="@("Batch")">Batch Barcode (One per Batch)</MudSelectItem>
                        <MudSelectItem Value="@("Unique")">Unique Barcode (One per Piece)</MudSelectItem>
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDialog" Variant="Variant.Text" Color="Color.Secondary">Cancel</MudButton>
        <MudButton OnClick="SaveItem" Variant="Variant.Filled" Color="Color.Primary" Disabled="@_saving">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
            }
            else
            {
                <MudText>Save</MudText>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<Item> _items = new();
    private List<Category> _categories = new();
    private List<Unit> _units = new();
    private bool _loading = true;
    private bool _saving = false;
    private string _searchString = "";

    // Dialog state
    private bool _dialogOpen = false;
    private bool _isFormValid = false;
    private MudForm? _form;
    private Item _editItem = new();
    private readonly DialogOptions _dialogOptions = new() { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true };

    protected override async Task OnInitializedAsync()
    {
        await LoadDropdowns();
        await LoadItems();
    }

    private async Task LoadDropdowns()
    {
        try
        {
            _categories = await Http.GetFromJsonAsync<List<Category>>("api/masters/categories") ?? new();
            _units = await Http.GetFromJsonAsync<List<Unit>>("api/masters/units") ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading lookup details: {ex.Message}", Severity.Error);
        }
    }

    private async Task LoadItems()
    {
        _loading = true;
        try
        {
            _items = await Http.GetFromJsonAsync<List<Item>>("api/masters/items") ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading items: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private bool FilterFunc(Item element) => 
        string.IsNullOrWhiteSpace(_searchString) || 
        element.Code.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
        element.Name.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
        (element.Category != null && element.Category.Name.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) ||
        (element.Brand != null && element.Brand.Contains(_searchString, StringComparison.OrdinalIgnoreCase));

    private void OpenAddDialog()
    {
        _editItem = new Item
        {
            BarcodeType = "Batch",
            CategoryId = _categories.FirstOrDefault()?.Id ?? Guid.Empty,
            UnitId = _units.FirstOrDefault()?.Id ?? Guid.Empty
        };
        _dialogOpen = true;
    }

    private void OpenEditDialog(Item item)
    {
        _editItem = new Item
        {
            Id = item.Id,
            Code = item.Code,
            Name = item.Name,
            CategoryId = item.CategoryId,
            UnitId = item.UnitId,
            Brand = item.Brand,
            HSNCode = item.HSNCode,
            MinimumStock = item.MinimumStock,
            ReorderLevel = item.ReorderLevel,
            BarcodeType = item.BarcodeType,
            CreatedAt = item.CreatedAt
        };
        _dialogOpen = true;
    }

    private void CloseDialog()
    {
        _dialogOpen = false;
    }

    private async Task SaveItem()
    {
        if (_form == null) return;
        await _form.Validate();
        if (!_form.IsValid) return;

        _saving = true;
        try
        {
            HttpResponseMessage response;
            if (_editItem.Id == Guid.Empty)
            {
                response = await Http.PostAsJsonAsync("api/masters/items", _editItem);
            }
            else
            {
                response = await Http.PutAsJsonAsync($"api/masters/items/{_editItem.Id}", _editItem);
            }

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Item details saved successfully!", Severity.Success);
                _dialogOpen = false;
                await LoadItems();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Save failed: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ConfirmDelete(Item item)
    {
        bool? confirm = await DialogService.ShowMessageBoxAsync(
            "Delete Item", 
            $"Are you sure you want to delete item '{item.Name}'?", 
            yesText: "Delete", cancelText: "Cancel");

        if (confirm == true)
        {
            try
            {
                var response = await Http.DeleteAsync($"api/masters/items/{item.Id}");
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Item deleted successfully!", Severity.Success);
                    await LoadItems();
                }
                else
                {
                    var error = await response.Content.ReadAsStringAsync();
                    Snackbar.Add($"Delete failed: {error}", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting: {ex.Message}", Severity.Error);
            }
        }
    }
}
