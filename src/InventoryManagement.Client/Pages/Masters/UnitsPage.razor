@page "/masters/units"
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Unit Master - AG Inventory</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-2">
    <div class="d-flex justify-between align-center mb-6">
        <div>
            <MudText Typo="Typo.h4" Class="font-weight-bold animated-gradient-text" Style="font-family: 'Outfit';">
                Unit Master
            </MudText>
            <MudText Typo="Typo.body2" Class="text-slate-400">
                Manage stock item unit identifiers (e.g., PCS, KG, MTR, BOX)
            </MudText>
        </div>
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenAddDialog"
                   Style="background: linear-gradient(135deg, #5C5CFF 0%, #00E5FF 100%); font-family: 'Outfit'; font-weight: 600;">
            Add Unit
        </MudButton>
    </div>

    <MudTable Items="@_units" 
              Hover="true" 
              Loading="@_loading" 
              SearchString="@_searchString" 
              Filter="new Func<Unit, bool>(FilterFunc)"
              Class="glass-panel text-slate-200">
        <ToolBarContent>
            <MudText Typo="Typo.h6" Style="font-family: 'Outfit'; color: #E2E8F0;">Units list</MudText>
            <MudSpacer />
            <MudTextField @bind-Value="_searchString" 
                          Placeholder="Search units..." 
                          Adornment="Adornment.Start" 
                          AdornmentIcon="@Icons.Material.Filled.Search" 
                          IconSize="Size.Medium" 
                          Class="mt-0 text-slate-200" 
                          Style="color: white;"/>
        </ToolBarContent>
        <HeaderContent>
            <MudTh Style="color: #94A3B8;">Code</MudTh>
            <MudTh Style="color: #94A3B8;">Unit Name</MudTh>
            <MudTh Style="color: #94A3B8;">Created Date</MudTh>
            <MudTh Style="color: #94A3B8; text-align: right;">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Code" Class="text-slate-100 font-weight-bold">
                <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Text">@context.Code</MudChip>
            </MudTd>
            <MudTd DataLabel="Unit Name" Class="text-slate-200">@context.Name</MudTd>
            <MudTd DataLabel="Created Date" Class="text-slate-300">@context.CreatedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</MudTd>
            <MudTd DataLabel="Actions" Style="text-align: right;">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Info" Size="Size.Small" OnClick="@(() => OpenEditDialog(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => ConfirmDelete(context))" />
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
</MudContainer>

<!-- Dialog for Add/Edit -->
<MudDialog @bind-Visible="_dialogOpen" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="font-family: 'Outfit'; color: white;">
            @(_editUnit.Id == Guid.Empty ? "Create New Unit" : "Edit Unit")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isFormValid">
            <MudTextField T="string" 
                          Label="Unit Code (e.g., PCS)" 
                          @bind-Value="_editUnit.Code" 
                          Required="true" 
                          RequiredError="Unit code is required" 
                          MaxLength="10"
                          Class="text-slate-200 mb-4" />
                          
            <MudTextField T="string" 
                          Label="Unit Name (e.g., Pieces)" 
                          @bind-Value="_editUnit.Name" 
                          Required="true" 
                          RequiredError="Unit name is required" 
                          MaxLength="50"
                          Class="text-slate-200" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDialog" Variant="Variant.Text" Color="Color.Secondary">Cancel</MudButton>
        <MudButton OnClick="SaveUnit" Variant="Variant.Filled" Color="Color.Primary" Disabled="@(!_isFormValid || _saving)">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
            }
            else
            {
                <MudText>Save</MudText>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<Unit> _units = new();
    private bool _loading = true;
    private bool _saving = false;
    private string _searchString = "";

    // Dialog state
    private bool _dialogOpen = false;
    private bool _isFormValid = false;
    private MudForm? _form;
    private Unit _editUnit = new();
    private readonly DialogOptions _dialogOptions = new() { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };

    protected override async Task OnInitializedAsync()
    {
        await LoadUnits();
    }

    private async Task LoadUnits()
    {
        _loading = true;
        try
        {
            _units = await Http.GetFromJsonAsync<List<Unit>>("api/masters/units") ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading units: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private bool FilterFunc(Unit element) => 
        string.IsNullOrWhiteSpace(_searchString) || 
        element.Code.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
        element.Name.Contains(_searchString, StringComparison.OrdinalIgnoreCase);

    private void OpenAddDialog()
    {
        _editUnit = new Unit();
        _dialogOpen = true;
    }

    private void OpenEditDialog(Unit unit)
    {
        _editUnit = new Unit { Id = unit.Id, Code = unit.Code, Name = unit.Name, CreatedAt = unit.CreatedAt };
        _dialogOpen = true;
    }

    private void CloseDialog()
    {
        _dialogOpen = false;
    }

    private async Task SaveUnit()
    {
        if (_form == null) return;
        await _form.Validate();
        if (!_form.IsValid) return;

        _saving = true;
        try
        {
            HttpResponseMessage response;
            if (_editUnit.Id == Guid.Empty)
            {
                response = await Http.PostAsJsonAsync("api/masters/units", _editUnit);
            }
            else
            {
                response = await Http.PutAsJsonAsync($"api/masters/units/{_editUnit.Id}", _editUnit);
            }

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Unit saved successfully!", Severity.Success);
                _dialogOpen = false;
                await LoadUnits();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Save failed: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ConfirmDelete(Unit unit)
    {
        bool? confirm = await DialogService.ShowMessageBoxAsync(
            "Delete Unit", 
            $"Are you sure you want to delete unit '{unit.Code}'?", 
            yesText: "Delete", cancelText: "Cancel");

        if (confirm == true)
        {
            try
            {
                var response = await Http.DeleteAsync($"api/masters/units/{unit.Id}");
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Unit deleted successfully!", Severity.Success);
                    await LoadUnits();
                }
                else
                {
                    var error = await response.Content.ReadAsStringAsync();
                    Snackbar.Add($"Delete failed: {error}", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting: {ex.Message}", Severity.Error);
            }
        }
    }
}
